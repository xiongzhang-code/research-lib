#!/usr/bin/env python3
"""Launch research_lib MCP servers with an explicit cluster profile."""

from __future__ import annotations

import json
import os
import shlex
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_ENV_FILE = Path("/home/xiongzhang/.config/research_lib/env")

SERVERS = {
    "admlq": "admlq_mcp.py",
    "nio": "nio_mcp.py",
    "optq": "optq_mcp.py",
    "dpvcfg": "dpvcfg_mcp.py",
    "gpu-monitor": "gpu_monitor_mcp.py",
    "submission": "submission_mcp.py",
    "history-index": "history_index_mcp.py",
}


def parse_env_file(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            raise SystemExit(f"invalid env line in {path}: {raw_line!r}")
        key, value = line.split("=", 1)
        key = key.strip()
        if not key:
            raise SystemExit(f"invalid empty env key in {path}: {raw_line!r}")
        values[key] = shlex.split(value, comments=False)[0] if value.strip() else ""
    return values


def env_name(prefix: str, key: str) -> str:
    return f"{prefix}_{key.upper().replace('-', '_')}"


def load_profile(cluster: str) -> tuple[Path, dict]:
    profile_path = REPO_ROOT / "config" / "clusters" / f"{cluster}.json"
    if not profile_path.exists():
        raise SystemExit(f"research_lib cluster profile not found: {profile_path}")
    profile = json.loads(profile_path.read_text(encoding="utf-8"))
    if profile.get("cluster") != cluster:
        raise SystemExit(f"profile {profile_path} has mismatched cluster={profile.get('cluster')!r}")
    return profile_path, profile


def profile_env(profile_path: Path, profile: dict, base_env: dict[str, str]) -> dict[str, str]:
    env = dict(base_env)
    env["RESEARCH_CLUSTER"] = str(profile["cluster"])
    env["RESEARCH_PROFILE_PATH"] = str(profile_path)
    env["RESEARCH_PROFILE_JSON"] = json.dumps(profile, ensure_ascii=False, sort_keys=True)

    for key, value in profile.get("paths", {}).items():
        env[env_name("RESEARCH", key)] = str(value)
    for key, value in profile.get("bins", {}).items():
        env[env_name("RESEARCH_BIN", key)] = str(value)
    for key, value in profile.get("behavior", {}).items():
        env[env_name("RESEARCH", key)] = "true" if bool(value) else "false"
    return env


def main(argv: list[str]) -> int:
    if len(argv) < 2 or argv[1] in {"-h", "--help"}:
        names = ", ".join(sorted(SERVERS))
        print(f"usage: research-mcp <server> [server args...]\nservers: {names}", file=sys.stderr)
        return 2

    server = argv[1]
    if server not in SERVERS:
        names = ", ".join(sorted(SERVERS))
        raise SystemExit(f"unknown research MCP server {server!r}; expected one of: {names}")

    env_file = Path(os.environ.get("RESEARCH_LIB_ENV", str(DEFAULT_ENV_FILE)))
    file_env = parse_env_file(env_file)
    cluster = file_env.get("RESEARCH_CLUSTER") or os.environ.get("RESEARCH_CLUSTER")
    if not cluster:
        raise SystemExit(
            f"RESEARCH_CLUSTER is not set; add it to {env_file} or export it in the process environment"
        )

    profile_path, profile = load_profile(cluster)
    child_env = profile_env(profile_path, profile, {**os.environ, **file_env})
    script = REPO_ROOT / "mcps" / SERVERS[server]
    if not script.exists():
        raise SystemExit(f"MCP server script not found: {script}")

    python = child_env.get("RESEARCH_BIN_PYTHON", sys.executable)
    os.execvpe(python, [python, str(script), *argv[2:]], child_env)
    return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))

